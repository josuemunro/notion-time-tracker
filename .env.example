# Backend Configuration
BACKEND_PORT=3001
DATABASE_PATH=/data/notion_time_tracker.sqlite

# Frontend Configuration
FRONTEND_PORT=3000

# Notion API Configuration (get these from https://www.notion.so/my-integrations)
NOTION_API_KEY=your_notion_integration_token_here
NOTION_CLIENTS_DB_ID=your_clients_database_id_here
NOTION_PROJECTS_DB_ID=your_projects_database_id_here
NOTION_TASKS_DB_ID=your_tasks_database_id_here
